{
  "name": "adranna-systems-website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite dev",
    "dev:backend": "convex dev",
    "build": "vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "codegen": "npm run codegen:paraglide && npm run codegen:convex",
    "codegen:paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "codegen:convex": "convex codegen",
    "telegram:sync-commands": "node --experimental-strip-types scripts/sync-telegram-commands.ts",
    "precommit": "npm run format && npm run codegen && npm run typecheck && npm run lint && npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@base-ui/react": "^1.2.0",
    "@clerk/clerk-react": "^5.61.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@inlang/paraglide-js": "^2.15.2",
    "@tanstack/react-router": "^1.161.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "lucide-react": "^1.7.0",
    "neverthrow": "^8.2.0",
    "posthog-js": "^1.366.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-onesignal": "^3.5.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
